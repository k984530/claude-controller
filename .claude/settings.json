{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/choiwon/Desktop/Orchestration/controller/bin/hooks/pre-safety-guard.sh",
            "timeout": 10,
            "statusMessage": "Safety guard..."
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/choiwon/Desktop/Orchestration/controller/bin/hooks/pre-write-guard.sh",
            "timeout": 10,
            "statusMessage": "Write guard..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/choiwon/Desktop/Orchestration/controller/bin/hooks/post-edit-test.sh",
            "timeout": 60,
            "statusMessage": "Running tests..."
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/choiwon/Desktop/Orchestration/controller/bin/hooks/audit-log.sh",
            "timeout": 5,
            "statusMessage": "Logging..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/choiwon/Desktop/Orchestration/controller/bin/hooks/stop-quality-gate.sh",
            "timeout": 120,
            "statusMessage": "Quality gate..."
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/choiwon/Desktop/Orchestration/controller/bin/hooks/notify-completion.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
