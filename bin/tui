#!/usr/bin/env python3
"""
Controller TUI — 터미널 인터랙티브 프로그램
curses 기반 대시보드 + 명령어 입력
"""

import curses
import json
import os
import re
import signal
import subprocess
import sys
import time
from pathlib import Path

# ── 경로 설정 ──────────────────────────────────────────────
SCRIPT_DIR = Path(__file__).resolve().parent
CONTROLLER_DIR = SCRIPT_DIR.parent
LOGS_DIR = CONTROLLER_DIR / "logs"
QUEUE_DIR = CONTROLLER_DIR / "queue"
SESSIONS_DIR = CONTROLLER_DIR / "sessions"
FIFO_PATH = QUEUE_DIR / "controller.pipe"
PID_FILE = CONTROLLER_DIR / "service" / "controller.pid"
SERVICE_SCRIPT = CONTROLLER_DIR / "service" / "controller.sh"
CONFIG_FILE = CONTROLLER_DIR / "config.sh"

# ── config.sh 에서 설정 읽기 ──────────────────────────────
def load_config():
    """config.sh 에서 KEY=VALUE 파싱"""
    cfg = {}
    if CONFIG_FILE.exists():
        for line in CONFIG_FILE.read_text().splitlines():
            line = line.strip()
            if not line or line.startswith("#"):
                continue
            m = re.match(r'^(\w+)=["\'"]?(.+?)["\'"]?\s*$', line)
            if m:
                cfg[m.group(1)] = m.group(2)
    return cfg


# ── 유틸리티 ──────────────────────────────────────────────
def parse_meta_file(filepath):
    data = {}
    try:
        with open(filepath, "r") as f:
            for line in f:
                line = line.strip()
                if not line or line.startswith("#"):
                    continue
                m = re.match(r"^(\w+)=(.*)$", line)
                if m:
                    key, val = m.group(1), m.group(2)
                    if len(val) >= 2 and val[0] == val[-1] and val[0] in ("'", '"'):
                        val = val[1:-1]
                    data[key] = val
    except (OSError, IOError):
        pass
    return data


def is_service_running():
    if not PID_FILE.exists():
        return False, None
    try:
        pid = int(PID_FILE.read_text().strip())
        os.kill(pid, 0)
        return True, pid
    except (ValueError, ProcessLookupError, PermissionError, OSError):
        return False, None


def get_all_jobs():
    jobs = []
    if not LOGS_DIR.exists():
        return jobs
    for mf in sorted(LOGS_DIR.glob("job_*.meta")):
        meta = parse_meta_file(mf)
        if not meta:
            continue
        if meta.get("STATUS") == "running" and meta.get("PID"):
            try:
                os.kill(int(meta["PID"]), 0)
            except (ProcessLookupError, ValueError, OSError):
                meta["STATUS"] = "done"

        result_text = None
        cost_usd = None
        job_id = meta.get("JOB_ID", "")
        if meta.get("STATUS") in ("done", "failed"):
            out_file = LOGS_DIR / f"job_{job_id}.out"
            if out_file.exists():
                try:
                    for line in open(out_file, "r"):
                        try:
                            obj = json.loads(line.strip())
                            if obj.get("type") == "result":
                                result_text = obj.get("result", "")
                                cost_usd = obj.get("total_cost_usd")
                        except json.JSONDecodeError:
                            continue
                except OSError:
                    pass

        jobs.append({
            "job_id":   job_id,
            "status":   meta.get("STATUS", "unknown"),
            "pid":      meta.get("PID", ""),
            "prompt":   meta.get("PROMPT", ""),
            "created":  meta.get("CREATED_AT", ""),
            "worktree": meta.get("WORKTREE", ""),
            "result":   result_text,
            "cost":     cost_usd,
        })
    return jobs


def get_job_result(job_id):
    out_file = LOGS_DIR / f"job_{job_id}.out"
    if not out_file.exists():
        return None
    try:
        content = out_file.read_text()
        for line in content.strip().split("\n"):
            try:
                obj = json.loads(line)
                if obj.get("type") == "result":
                    return obj.get("result", "")
            except json.JSONDecodeError:
                continue
        try:
            data = json.loads(content)
            return data.get("result", content[:2000])
        except json.JSONDecodeError:
            return content[:2000]
    except OSError:
        return None


def send_to_fifo(prompt, cwd=None, worktree=False, repo=None):
    if not FIFO_PATH.exists():
        return None, "FIFO 없음 — 서비스가 실행 중이 아닙니다"
    job_id = f"{int(time.time())}-tui-{os.getpid()}-{id(prompt) % 10000}"
    payload = {"id": job_id, "prompt": prompt}
    if cwd:
        payload["cwd"] = cwd
    if worktree:
        payload["worktree"] = "true"
    if repo:
        payload["repo"] = repo
    try:
        fd = os.open(str(FIFO_PATH), os.O_WRONLY | os.O_NONBLOCK)
        with os.fdopen(fd, "w") as f:
            f.write(json.dumps(payload, ensure_ascii=False) + "\n")
        return job_id, None
    except OSError as e:
        return None, f"전송 실패: {e}"


def start_service():
    running, pid = is_service_running()
    if running:
        return True, pid
    LOGS_DIR.mkdir(parents=True, exist_ok=True)
    QUEUE_DIR.mkdir(parents=True, exist_ok=True)
    SESSIONS_DIR.mkdir(parents=True, exist_ok=True)
    subprocess.Popen(
        ["bash", str(SERVICE_SCRIPT), "start"],
        stdout=open(LOGS_DIR / "service.log", "a"),
        stderr=subprocess.STDOUT,
        stdin=subprocess.DEVNULL,
        start_new_session=True,
        cwd=str(CONTROLLER_DIR),
    )
    for _ in range(30):
        time.sleep(0.1)
        running, pid = is_service_running()
        if running:
            return True, pid
    return False, None


def stop_service():
    running, pid = is_service_running()
    if not running:
        return False
    try:
        os.kill(pid, signal.SIGTERM)
        return True
    except OSError:
        return False


def kill_job(job_id):
    meta_file = LOGS_DIR / f"job_{job_id}.meta"
    if not meta_file.exists():
        return False, "작업을 찾을 수 없습니다"
    meta = parse_meta_file(meta_file)
    pid_str = meta.get("PID", "")
    if pid_str:
        try:
            pid = int(pid_str)
            os.kill(pid, signal.SIGTERM)
            return True, None
        except (ValueError, ProcessLookupError, OSError):
            pass
    return False, "PID 없음 또는 이미 종료됨"


def clean_done_jobs():
    count = 0
    for mf in list(LOGS_DIR.glob("job_*.meta")):
        meta = parse_meta_file(mf)
        if meta.get("STATUS") in ("done", "failed"):
            job_id = meta.get("JOB_ID", "")
            out_file = LOGS_DIR / f"job_{job_id}.out"
            try:
                mf.unlink()
                if out_file.exists():
                    out_file.unlink()
                count += 1
            except OSError:
                pass
    return count


# ── TUI 클래스 ─────────────────────────────────────────────

class ControllerTUI:
    def __init__(self, stdscr):
        self.stdscr = stdscr
        self.jobs = []
        self.selected = 0
        self.mode = "dashboard"  # dashboard | input | result | help
        self.input_buf = ""
        self.input_label = ""
        self.input_callback = None
        self.message = ""
        self.message_time = 0
        self.result_lines = []
        self.result_scroll = 0
        self.worktree_mode = False
        self.target_repo = ""
        self.cwd = os.getcwd()
        self.last_refresh = 0

        # 설정 로드
        cfg = load_config()
        self.target_repo = cfg.get("TARGET_REPO", os.environ.get("TARGET_REPO", ""))

        curses.start_color()
        curses.use_default_colors()
        curses.init_pair(1, curses.COLOR_GREEN, -1)    # 성공/실행중
        curses.init_pair(2, curses.COLOR_RED, -1)       # 실패
        curses.init_pair(3, curses.COLOR_YELLOW, -1)    # 경고
        curses.init_pair(4, curses.COLOR_CYAN, -1)      # 강조
        curses.init_pair(5, curses.COLOR_MAGENTA, -1)   # worktree
        curses.init_pair(6, curses.COLOR_WHITE, curses.COLOR_BLUE)  # 선택됨
        curses.init_pair(7, curses.COLOR_BLACK, curses.COLOR_WHITE) # 헤더
        curses.curs_set(0)
        self.stdscr.nodelay(True)
        self.stdscr.keypad(True)

    def set_message(self, msg):
        self.message = msg
        self.message_time = time.time()

    def refresh_jobs(self):
        now = time.time()
        if now - self.last_refresh > 1.5:
            self.jobs = get_all_jobs()
            self.last_refresh = now
            if self.selected >= len(self.jobs):
                self.selected = max(0, len(self.jobs) - 1)

    def draw_header(self):
        h, w = self.stdscr.getmaxyx()
        running, pid = is_service_running()

        # 상단 바
        header = " Controller TUI "
        svc_status = f" SVC: PID {pid} " if running else " SVC: STOPPED "
        job_running = sum(1 for j in self.jobs if j["status"] == "running")
        job_total = len(self.jobs)
        job_info = f" Jobs: {job_running}/{job_total} "
        wt_info = " [WT]" if self.worktree_mode else ""

        bar = f"{header}|{svc_status}|{job_info}{wt_info}"
        bar = bar.ljust(w - 1)[:w - 1]

        try:
            self.stdscr.addstr(0, 0, bar, curses.color_pair(7) | curses.A_BOLD)
        except curses.error:
            pass

    def draw_jobs(self, start_y):
        h, w = self.stdscr.getmaxyx()
        max_rows = h - start_y - 4  # 하단 명령줄 공간 확보

        # 컬럼 헤더
        hdr = f" {'#':>3}  {'상태':<8}  {'PID':<7}  {'WT':<12}  {'생성시간':<19}  {'프롬프트'}"
        hdr = hdr[:w - 1].ljust(w - 1)
        try:
            self.stdscr.addstr(start_y, 0, hdr, curses.A_BOLD | curses.A_UNDERLINE)
        except curses.error:
            pass

        if not self.jobs:
            try:
                self.stdscr.addstr(start_y + 2, 2, "(작업 없음)", curses.color_pair(3))
            except curses.error:
                pass
            return start_y + 4

        row = start_y + 1
        for i, job in enumerate(self.jobs):
            if row >= h - 3:
                break

            jid = job["job_id"]
            status = job["status"]
            pid = job.get("pid", "") or "-"
            wt = os.path.basename(job.get("worktree", "")) if job.get("worktree") else "-"
            created = job.get("created", "")[:19]
            prompt = job.get("prompt", "")

            # 상태 표시 및 색상
            if status == "running":
                st_str = "● 실행중"
                color = curses.color_pair(1) | curses.A_BOLD
            elif status == "done":
                st_str = "✓ 완료 "
                color = curses.color_pair(1)
            elif status == "failed":
                st_str = "✗ 실패 "
                color = curses.color_pair(2)
            else:
                st_str = f"  {status[:6]}"
                color = curses.color_pair(3)

            # 프롬프트 잘라내기
            max_prompt = w - 60
            if max_prompt > 0:
                if len(prompt) > max_prompt:
                    prompt = prompt[:max_prompt - 3] + "..."
            else:
                prompt = ""

            # worktree 잘라내기
            if len(wt) > 12:
                wt = wt[:11] + "~"

            line = f" {jid:>3}  {st_str:<8}  {pid:<7}  {wt:<12}  {created:<19}  {prompt}"
            line = line[:w - 1]

            attr = color
            if i == self.selected:
                attr = curses.color_pair(6) | curses.A_BOLD
                line = line.ljust(w - 1)

            try:
                self.stdscr.addstr(row, 0, line, attr)
            except curses.error:
                pass
            row += 1

        return row + 1

    def draw_footer(self):
        h, w = self.stdscr.getmaxyx()

        # 메시지 표시 (3초간)
        if self.message and time.time() - self.message_time < 3:
            try:
                msg = f" {self.message}"[:w - 1]
                self.stdscr.addstr(h - 3, 0, msg, curses.color_pair(3))
            except curses.error:
                pass

        # 명령어 도움말
        cmds = "[s]end  [r]esult  [k]ill  [w]orktree  [c]lean  [S]vc  [h]elp  [q]uit"
        try:
            self.stdscr.addstr(h - 2, 0, cmds[:w - 1], curses.A_DIM)
        except curses.error:
            pass

        # 상태 표시줄
        wt_label = f"WT: ON ({self.target_repo})" if self.worktree_mode else "WT: OFF"
        cwd_label = f"CWD: {self.cwd}"
        status_line = f" {wt_label} | {cwd_label}"
        try:
            self.stdscr.addstr(h - 1, 0, status_line[:w - 1].ljust(w - 1),
                             curses.color_pair(7))
        except curses.error:
            pass

    def draw_input(self):
        h, w = self.stdscr.getmaxyx()
        curses.curs_set(1)

        # 입력 프롬프트
        try:
            self.stdscr.addstr(h // 2 - 2, 2, f"─── {self.input_label} ───",
                             curses.color_pair(4) | curses.A_BOLD)
            self.stdscr.addstr(h // 2, 2, "> " + self.input_buf + "█",
                             curses.color_pair(4))
            self.stdscr.addstr(h // 2 + 2, 2, "[Enter] 확인  [Esc] 취소",
                             curses.A_DIM)
        except curses.error:
            pass

    def draw_result(self):
        h, w = self.stdscr.getmaxyx()

        try:
            self.stdscr.addstr(0, 0, " [결과 보기] ↑↓ 스크롤 | q/Esc 닫기 ".ljust(w - 1),
                             curses.color_pair(7) | curses.A_BOLD)
        except curses.error:
            pass

        max_rows = h - 2
        visible = self.result_lines[self.result_scroll:self.result_scroll + max_rows]

        for i, line in enumerate(visible):
            try:
                self.stdscr.addstr(i + 1, 0, line[:w - 1])
            except curses.error:
                pass

        # 스크롤 위치
        total = len(self.result_lines)
        if total > max_rows:
            pct = int((self.result_scroll / max(1, total - max_rows)) * 100)
            try:
                self.stdscr.addstr(h - 1, 0, f" [{self.result_scroll + 1}-{min(self.result_scroll + max_rows, total)}/{total}] {pct}% ".ljust(w - 1),
                                 curses.color_pair(7))
            except curses.error:
                pass

    def draw_help(self):
        h, w = self.stdscr.getmaxyx()
        lines = [
            "",
            "  Controller TUI — 명령어 도움말",
            "  ════════════════════════════════════════",
            "",
            "  s, Enter    프롬프트 전송 (새 작업 생성)",
            "  r           선택된 작업의 결과 보기",
            "  k           선택된 작업 강제 종료",
            "  d           선택된 작업 삭제 (완료된 것만)",
            "  w           Worktree 모드 토글",
            "  W           Worktree 목록 보기",
            "  c           완료된 작업 일괄 정리",
            "  S           서비스 시작/종료 토글",
            "  R           TARGET_REPO 변경",
            "  D           CWD(작업 디렉토리) 변경",
            "",
            "  ↑/↓, j/k    작업 선택 이동",
            "  h, ?         이 도움말",
            "  q            프로그램 종료",
            "",
            "  ════════════════════════════════════════",
            "  Worktree 모드: 각 작업이 독립된 git worktree에서",
            "  실행됩니다. TARGET_REPO가 설정되어야 합니다.",
            "",
            "  [아무 키나 누르면 닫힘]",
        ]
        for i, line in enumerate(lines):
            if i >= h - 1:
                break
            try:
                attr = curses.color_pair(4) | curses.A_BOLD if i in (1, 2) else 0
                self.stdscr.addstr(i, 0, line[:w - 1], attr)
            except curses.error:
                pass

    def enter_input_mode(self, label, callback):
        self.mode = "input"
        self.input_label = label
        self.input_buf = ""
        self.input_callback = callback

    def handle_input_key(self, key):
        if key == 27:  # Esc
            self.mode = "dashboard"
            curses.curs_set(0)
            return
        if key in (10, 13):  # Enter
            self.mode = "dashboard"
            curses.curs_set(0)
            if self.input_callback and self.input_buf.strip():
                self.input_callback(self.input_buf.strip())
            return
        if key in (curses.KEY_BACKSPACE, 127, 8):
            self.input_buf = self.input_buf[:-1]
            return
        if 32 <= key <= 126:
            self.input_buf += chr(key)
        # 한글 등 멀티바이트 처리 — curses.get_wch 로 전환 필요시
        # 지금은 ASCII 입력만 지원

    def handle_result_key(self, key):
        h, _ = self.stdscr.getmaxyx()
        max_rows = h - 2

        if key in (ord('q'), ord('Q'), 27):
            self.mode = "dashboard"
            return
        if key in (curses.KEY_UP, ord('k')):
            self.result_scroll = max(0, self.result_scroll - 1)
        elif key in (curses.KEY_DOWN, ord('j')):
            self.result_scroll = min(
                max(0, len(self.result_lines) - max_rows),
                self.result_scroll + 1
            )
        elif key == curses.KEY_PPAGE:
            self.result_scroll = max(0, self.result_scroll - max_rows)
        elif key == curses.KEY_NPAGE:
            self.result_scroll = min(
                max(0, len(self.result_lines) - max_rows),
                self.result_scroll + max_rows
            )

    def do_send(self, prompt_text):
        job_id, err = send_to_fifo(
            prompt_text,
            cwd=self.cwd,
            worktree=self.worktree_mode,
            repo=self.target_repo if self.worktree_mode else None,
        )
        if err:
            self.set_message(f"전송 실패: {err}")
        else:
            self.set_message(f"전송 완료 → Job ID: {job_id}")
            self.last_refresh = 0  # 즉시 새로고침

    def do_view_result(self):
        if not self.jobs:
            self.set_message("작업 없음")
            return
        job = self.jobs[self.selected]
        jid = job["job_id"]
        result = get_job_result(jid)
        if result:
            self.result_lines = result.split("\n")
            self.result_scroll = 0
            self.mode = "result"
        else:
            self.set_message(f"Job #{jid}: 결과 없음 (아직 실행 중이거나 출력 없음)")

    def do_kill(self):
        if not self.jobs:
            return
        job = self.jobs[self.selected]
        ok, err = kill_job(job["job_id"])
        if ok:
            self.set_message(f"Job #{job['job_id']} 종료 신호 전송")
        else:
            self.set_message(f"종료 실패: {err}")
        self.last_refresh = 0

    def do_delete_job(self):
        if not self.jobs:
            return
        job = self.jobs[self.selected]
        if job["status"] == "running":
            self.set_message("실행 중인 작업은 삭제할 수 없습니다")
            return
        jid = job["job_id"]
        meta = LOGS_DIR / f"job_{jid}.meta"
        out = LOGS_DIR / f"job_{jid}.out"
        try:
            if meta.exists():
                meta.unlink()
            if out.exists():
                out.unlink()
            self.set_message(f"Job #{jid} 삭제됨")
        except OSError as e:
            self.set_message(f"삭제 실패: {e}")
        self.last_refresh = 0

    def do_clean(self):
        count = clean_done_jobs()
        self.set_message(f"{count}개 작업 정리됨")
        self.last_refresh = 0

    def do_toggle_worktree(self):
        if not self.worktree_mode:
            if not self.target_repo:
                self.enter_input_mode(
                    "TARGET_REPO 경로 입력 (git 저장소)",
                    self._set_repo_and_enable_wt
                )
                return
            self.worktree_mode = True
            self.set_message(f"Worktree 모드 ON → {self.target_repo}")
        else:
            self.worktree_mode = False
            self.set_message("Worktree 모드 OFF")

    def _set_repo_and_enable_wt(self, path):
        path = os.path.expanduser(path)
        if os.path.isdir(os.path.join(path, ".git")):
            self.target_repo = path
            self.worktree_mode = True
            self.set_message(f"Worktree 모드 ON → {path}")
        else:
            self.set_message(f"git 저장소가 아닙니다: {path}")

    def do_toggle_service(self):
        running, pid = is_service_running()
        if running:
            if stop_service():
                self.set_message("서비스 종료 신호 전송")
            else:
                self.set_message("서비스 종료 실패")
        else:
            ok, pid = start_service()
            if ok:
                self.set_message(f"서비스 시작됨 (PID: {pid})")
            else:
                self.set_message("서비스 시작 실패")

    def do_show_worktrees(self):
        if not self.target_repo:
            self.set_message("TARGET_REPO 미설정")
            return
        try:
            out = subprocess.check_output(
                ["git", "-C", self.target_repo, "worktree", "list"],
                stderr=subprocess.DEVNULL, text=True
            )
            self.result_lines = ["=== Git Worktree 목록 ===", ""] + out.strip().split("\n")
            self.result_scroll = 0
            self.mode = "result"
        except (subprocess.CalledProcessError, OSError):
            self.set_message("worktree 목록 조회 실패")

    def run(self):
        # 서비스 자동 시작
        running, _ = is_service_running()
        if not running:
            start_service()

        while True:
            self.refresh_jobs()
            self.stdscr.erase()

            if self.mode == "dashboard":
                self.draw_header()
                next_y = self.draw_jobs(2)
                self.draw_footer()
            elif self.mode == "input":
                self.draw_header()
                self.draw_jobs(2)
                self.draw_input()
            elif self.mode == "result":
                self.draw_result()
            elif self.mode == "help":
                self.draw_help()

            self.stdscr.refresh()

            # 키 입력
            try:
                key = self.stdscr.getch()
            except curses.error:
                key = -1

            if key == -1:
                curses.napms(100)
                continue

            # 모드별 키 처리
            if self.mode == "input":
                self.handle_input_key(key)
                continue

            if self.mode == "result":
                self.handle_result_key(key)
                continue

            if self.mode == "help":
                self.mode = "dashboard"
                continue

            # Dashboard 모드 키 바인딩
            if key in (ord('q'), ord('Q')):
                break
            elif key in (ord('s'), 10, 13):  # s or Enter
                self.enter_input_mode("프롬프트 입력", self.do_send)
            elif key == ord('r'):
                self.do_view_result()
            elif key == ord('k'):
                self.do_kill()
            elif key == ord('d'):
                self.do_delete_job()
            elif key == ord('c'):
                self.do_clean()
            elif key == ord('w'):
                self.do_toggle_worktree()
            elif key == ord('W'):
                self.do_show_worktrees()
            elif key == ord('S'):
                self.do_toggle_service()
            elif key == ord('R'):
                self.enter_input_mode("TARGET_REPO 경로", self._set_repo_and_enable_wt)
            elif key == ord('D'):
                self.enter_input_mode("CWD(작업 디렉토리) 경로",
                                      lambda p: setattr(self, 'cwd', os.path.expanduser(p)))
            elif key in (ord('h'), ord('?')):
                self.mode = "help"
            elif key in (curses.KEY_UP, ord('k') if False else -999):
                # 위 화살표 — ord('k')는 kill에 매핑했으므로 화살표만
                pass
            elif key == curses.KEY_UP:
                self.selected = max(0, self.selected - 1)
            elif key == curses.KEY_DOWN:
                self.selected = min(max(0, len(self.jobs) - 1), self.selected + 1)
            elif key == ord('j'):
                self.selected = min(max(0, len(self.jobs) - 1), self.selected + 1)


def main(stdscr):
    tui = ControllerTUI(stdscr)
    tui.run()


if __name__ == "__main__":
    # 터미널 환경 확인
    if not sys.stdout.isatty():
        print("[오류] 터미널에서 실행해야 합니다.", file=sys.stderr)
        sys.exit(1)

    try:
        curses.wrapper(main)
    except KeyboardInterrupt:
        pass
    finally:
        print("\n  Controller TUI 종료됨.")
